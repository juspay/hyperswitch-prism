#!/usr/bin/env bash
# Git pre-push hook — blocks push if test report files contain unmasked
# credentials.
#
# Install:
#   cp scripts/pre-push-cred-check .git/hooks/pre-push
#   chmod +x .git/hooks/pre-push
#
# Or run:
#   scripts/install-pre-push-hook.sh

set -euo pipefail

# Only check when staged files include test_report/ content.
# This avoids penalising pushes that don't touch reports at all.
REPORT_DIR="crates/internal/integration-tests/test_report"

# Quick check: are any report files being pushed?
if ! git diff --name-only HEAD @{upstream} 2>/dev/null | grep -q "^${REPORT_DIR}/" ; then
    # No report files in the diff — skip the check.
    exit 0
fi

echo "[pre-push] Checking test report files for unmasked credentials..."

if cargo run -p integration-tests --bin check_report_creds 2>&1; then
    echo "[pre-push] Credential check passed."
    exit 0
else
    echo ""
    echo "[pre-push] BLOCKED: unmasked credentials detected in test reports."
    echo "  Run:  cargo run -p integration-tests --bin mask_report_creds"
    echo "  Then: git add -u && git commit --amend"
    exit 1
fi

{
    "name": "juspay/connector-service-php",
    "description": "Hyperswitch Payments PHP SDK — native FFI client for connector integrations via UniFFI C ABI",
    "type": "library",
    "keywords": ["payments", "connectors", "ffi", "hyperswitch", "juspay"],
    "license": "Apache-2.0",
    "require": {
        "php": ">=8.1",
        "ext-ffi": "*",
        "ext-json": "*",
        "google/protobuf": "^4.0",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Payments\\": "src/Payments/",
            "Types\\": "src/Payments/Generated/Types/",
            "GPBMetadata\\": "src/Payments/Generated/GPBMetadata/"
        },
        "files": [
            "src/Payments/_GeneratedServiceClients.php",
            "src/Payments/_GeneratedFlows.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit tests/"
    }
}

{
  "capture_full_amount": {
    "grpc_req": {
      "connector_transaction_id": "auto_generate",
      "amount_to_capture": {
        "minor_amount": 6000,
        "currency": "USD"
      },
      "merchant_capture_id": "auto_generate",
      "state": {
        "connector_customer_id": "",
        "access_token": {
          "token": {
            "value": ""
          },
          "token_type": "",
          "expires_in_seconds": 0
        }
      }
    },
    "assert": {
      "status": {
        "one_of": [
          "CHARGED",
          "PENDING"
        ]
      },
      "connector_transaction_id": {
        "must_exist": true
      },
      "error": {
        "must_not_exist": true
      }
    },
    "is_default": true
  },

{
  "void_authorized_payment": {
    "grpc_req": {
      "connector_transaction_id": "auto_generate",
      "merchant_void_id": "auto_generate",
      "state": {
        "connector_customer_id": "",
        "access_token": {
          "token": {
            "value": ""
          },
          "token_type": "",
          "expires_in_seconds": 0
        }
      },
      "cancellation_reason": "requested_by_customer"
    },
    "assert": {
      "status": {
        "one_of": [
          "VOIDED",
          "PENDING"
        ]
      },
      "connector_transaction_id": {
        "must_exist": true
      },
      "error": {
        "must_not_exist": true
      }
    },
    "is_default": true
  },
  "void_without_cancellation_reason": {
    "grpc_req": {
      "connector_transaction_id": "auto_generate",
      "merchant_void_id": "auto_generate",
      "state": {
        "connector_customer_id": "",
        "access_token": {
          "token": {
            "value": ""
          },
          "token_type": "",
          "expires_in_seconds": 0
        }
      }
    },
    "assert": {
      "status": {
        "one_of": [
          "VOIDED",
          "PENDING"
        ]
      },
      "connector_transaction_id": {
        "must_exist": true
      },
      "error": {
        "must_not_exist": true
      }
    }
  },
  "void_with_amount": {
    "grpc_req": {
      "connector_transaction_id": "auto_generate",
      "merchant_void_id": "auto_generate",
      "amount": {
        "minor_amount": 6000,
        "currency": "USD"
      },
      "merchant_order_id": "auto_generate",
      "state": {
        "connector_customer_id": "",
        "access_token": {
          "token": {
            "value": ""
          },
          "token_type": "",
          "expires_in_seconds": 0
        }
      },
      "cancellation_reason": "requested_by_customer"
    },
    "assert": {
      "status": {
        "one_of": [
          "VOIDED",
          "PENDING"
        ]
      },
      "connector_transaction_id": {
        "must_exist": true
      },
      "error": {
        "must_not_exist": true
      }
    }
  }
}

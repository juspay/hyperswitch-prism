{
  "recurring_charge": {
    "grpc_req": {
      "merchant_charge_id": "auto_generate",
      "connector_recurring_payment_id": {
        "connector_mandate_id": {
          "connector_mandate_id": "auto_generate"
        }
      },
      "amount": {
        "minor_amount": 6000,
        "currency": "USD"
      },
      "connector_customer_id": "",
      "customer": {
        "connector_customer_id": ""
      },
      "state": {
        "access_token": {
          "token": {
            "value": ""
          },
          "token_type": "",
          "expires_in_seconds": 0
        }
      }
    },
    "assert": {
      "connector_transaction_id": {
        "must_exist": true
      },
      "error": {
        "must_not_exist": true
      }

{
  "create_sdk_session_apple_pay": {
    "grpc_req": {
      "merchant_sdk_session_id": "auto_generate",
      "amount": {
        "minor_amount": 10000,
        "currency": "USD"
      },
      "payment_method_type": "APPLE_PAY",
      "country_alpha2_code": "US",
      "customer": {
        "name": "auto_generate",
        "email": {
          "value": "auto_generate"
        }
      }
    },
    "assert": {
      "session_token": {
        "must_exist": true
      },
      "error": {
        "must_not_exist": true
      }
    },
    "is_default": true,
    "display_name": "Create SDK Session Token | Create SDK Session Apple Pay"
  },

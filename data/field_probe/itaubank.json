  "flow_graph": {
    "nodes": {
      "authenticate": {
        "node_type": "dependent",
        "description": "authenticate"
      },
      "authorize": {
        "node_type": "entry_point",
        "description": "Authorize a payment, reserving funds",
        "provides": {
          "connector_transaction_id": {
            "response_path": "connector_transaction_id",
            "description": "Transaction ID for subsequent operations"
          }
        },
        "requires": {
          "access_token": {
            "from_flow": "create_access_token",
            "from_field": "access_token",
            "request_path": "state.access_token.token.value"
          },
          "order_id": {
            "from_flow": "create_order",
            "from_field": "order_id",
            "request_path": "merchant_order_id"
          }
        }
      },
      "capture": {
        "node_type": "dependent",
        "description": "Capture previously authorized funds",
        "requires": {
          "connector_transaction_id": {
            "from_flow": "authorize",
            "from_field": "connector_transaction_id",
            "request_path": "connector_transaction_id"
          }
        }
      },
      "create_access_token": {
        "node_type": "prerequisite",
        "description": "Obtain OAuth2 access token for API authentication",
        "provides": {
          "access_token": {
            "response_path": "state.access_token.token.value",
            "description": "OAuth2 access token for API calls"
          }
        }
      },
      "create_customer": {
        "node_type": "prerequisite",
        "description": "Create a customer profile for recurring payments",
        "provides": {
          "connector_customer_id": {
            "response_path": "connector_customer_id",
            "description": "Customer ID for recurring payments"
          }
        }
      },
      "create_order": {
        "node_type": "prerequisite",
        "description": "Create an order before payment authorization",
        "provides": {
          "order_id": {
            "response_path": "connector_order_id",
            "description": "Order ID for payment authorization"
          }
        }
      },
      "create_session_token": {
        "node_type": "dependent",
        "description": "create_session_token"
      },
      "dispute_accept": {
        "node_type": "dependent",
        "description": "dispute_accept"
      },
      "dispute_defend": {
        "node_type": "dependent",
        "description": "dispute_defend"
      },
      "dispute_submit_evidence": {
        "node_type": "dependent",
        "description": "dispute_submit_evidence"
      },
      "get": {
        "node_type": "dependent",
        "description": "Retrieve payment status and details",
        "requires": {
          "connector_transaction_id": {
            "from_flow": "authorize",
            "from_field": "connector_transaction_id",
            "request_path": "connector_transaction_id"
          }
        }
      },
      "post_authenticate": {
        "node_type": "dependent",
        "description": "post_authenticate"
      },
      "pre_authenticate": {
        "node_type": "entry_point",
        "description": "Pre-authenticate before capture"
      },
      "proxy_authorize": {
        "node_type": "dependent",
        "description": "proxy_authorize"
      },
      "proxy_setup_recurring": {
        "node_type": "dependent",
        "description": "proxy_setup_recurring"
      },
      "recurring_charge": {
        "node_type": "dependent",
        "description": "Charge against an existing mandate",
        "requires": {
          "connector_customer_id": {
            "from_flow": "create_customer",
            "from_field": "connector_customer_id",
            "request_path": "connector_customer_id"
          },
          "connector_recurring_payment_id": {
            "from_flow": "setup_recurring",
            "from_field": "mandate_reference",
            "request_path": "connector_recurring_payment_id.connector_mandate_id.connector_mandate_id"
          }
        }
      },
      "refund": {
        "node_type": "dependent",
        "description": "Refund a completed payment",
        "provides": {
          "refund_id": {
            "response_path": "connector_refund_id",
            "description": "Refund ID for tracking"
          }
        },
        "requires": {
          "connector_transaction_id": {
            "from_flow": "authorize",
            "from_field": "connector_transaction_id",
            "request_path": "connector_transaction_id"
          }
        }
      },
      "reverse": {
        "node_type": "dependent",
        "description": "reverse"
      },
      "setup_recurring": {
        "node_type": "entry_point",
        "description": "Set up a mandate for recurring charges",
        "provides": {
          "mandate_reference": {
            "response_path": "mandate_reference.connector_mandate_id.connector_mandate_id",
            "description": "Mandate reference for recurring charges"
          }
        }
      },
      "token_authorize": {
        "node_type": "dependent",
        "description": "token_authorize"
      },
      "token_setup_recurring": {
        "node_type": "dependent",
        "description": "token_setup_recurring"
      },
      "tokenize": {
        "node_type": "entry_point",
        "description": "Tokenize a payment method for later use",
        "provides": {
          "payment_method_token": {
            "response_path": "payment_method_token",
            "description": "Tokenized payment method"
          }
        }
      },
      "void": {
        "node_type": "dependent",
        "description": "Cancel an uncaptured authorization",
        "requires": {
          "connector_transaction_id": {
            "from_flow": "authorize",
            "from_field": "connector_transaction_id",
            "request_path": "connector_transaction_id"
          }
        }
      }
    },
    "edges": [
      {
        "from": "authorize",
        "to": "capture"
      },
      {
        "from": "authorize",
        "to": "get"
      },
      {
        "from": "authorize",
        "to": "refund"
      },
      {
        "from": "authorize",
        "to": "void"
      },
      {
        "from": "create_access_token",
        "to": "authorize"
      },
      {
        "from": "create_customer",
        "to": "recurring_charge"
      },
      {
        "from": "create_order",
        "to": "authorize"
      },
      {
        "from": "setup_recurring",
        "to": "recurring_charge"
      }
    ]
  }
}
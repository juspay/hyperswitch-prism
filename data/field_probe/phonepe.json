  "flow_graph": {
    "nodes": {
      "authenticate": {
        "node_type": "dependent",
        "description": "authenticate"
      },
      "authorize": {
        "node_type": "entry_point",
        "description": "Authorize a payment, reserving funds",
        "provides": {
          "connector_transaction_id": {
            "response_path": "connector_transaction_id",
            "description": "Transaction ID for subsequent operations"
          }
        },
        "requires": {
          "access_token": {
            "from_flow": "create_access_token",
            "from_field": "access_token",
            "request_path": "state.access_token.token.value"
          },
          "order_id": {
            "from_flow": "create_order",
            "from_field": "order_id",
            "request_path": "merchant_order_id"
          }
        }
      },
      "capture": {
        "node_type": "dependent",
        "description": "Capture previously authorized funds",
        "requires": {
          "connector_transaction_id": {
            "from_flow": "authorize",
            "from_field": "connector_transaction_id",
            "request_path": "connector_transaction_id"
          }
        }
      },
      "create_access_token": {
        "node_type": "prerequisite",
        "description": "Obtain OAuth2 access token for API authentication",
        "provides": {
          "access_token": {
            "response_path": "state.access_token.token.value",
            "description": "OAuth2 access token for API calls"
          }
        }
      },
      "create_customer": {
        "node_type": "prerequisite",
        "description": "Create a customer profile for recurring payments",
        "provides": {
          "connector_customer_id": {
            "response_path": "connector_customer_id",
            "description": "Customer ID for recurring payments"
          }
        }
      },
      "create_order": {
        "node_type": "prerequisite",
        "description": "Create an order before payment authorization",
        "provides": {
          "order_id": {
            "response_path": "connector_order_id",
            "description": "Order ID for payment authorization"
          }
        }
      },
      "create_session_token": {
        "node_type": "dependent",
        "description": "create_session_token"
      },
      "dispute_accept": {
        "node_type": "dependent",
        "description": "dispute_accept"
      },
      "dispute_defend": {
        "node_type": "dependent",
        "description": "dispute_defend"
      },
      "dispute_submit_evidence": {
        "node_type": "dependent",
        "description": "dispute_submit_evidence"
      },
      "get": {

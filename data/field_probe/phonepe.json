          "connector_recurring_payment_id": {
            "from_flow": "setup_recurring",
            "from_field": "mandate_reference",
            "request_path": "connector_recurring_payment_id.connector_mandate_id.connector_mandate_id"
          }
        }
      },
      "refund": {
        "node_type": "dependent",

        "node_type": "dependent",
        "description": "proxy_setup_recurring"
      },
      "recurring_charge": {
        "node_type": "dependent",
        "description": "Charge against an existing mandate",
        "requires": {
          "connector_customer_id": {
            "from_flow": "create_customer",
            "from_field": "connector_customer_id",
            "request_path": "connector_customer_id"
